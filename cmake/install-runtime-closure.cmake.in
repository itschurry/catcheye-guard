cmake_policy(PUSH)
cmake_policy(SET CMP0057 NEW)

set(_catcheye_sysroot "@TARGET_SYSROOT@")
set(_catcheye_readelf "@CMAKE_READELF@")
set(_catcheye_install_libdir "${CMAKE_INSTALL_PREFIX}/@CMAKE_INSTALL_LIBDIR@")
set(_catcheye_install_bindir "${CMAKE_INSTALL_PREFIX}/@CMAKE_INSTALL_BINDIR@")

set(_catcheye_search_dirs
    "${_catcheye_install_libdir}"
    "${_catcheye_sysroot}/usr/lib/aarch64-linux-gnu"
    "${_catcheye_sysroot}/lib/aarch64-linux-gnu"
    "${_catcheye_sysroot}/usr/lib"
    "${_catcheye_sysroot}/lib"
)

set(_catcheye_skip_runtime_regex
    "^(ld-linux|linux-vdso|libc\\.so|libm\\.so|libmvec\\.so|libdl\\.so|libpthread\\.so|librt\\.so|libutil\\.so|libresolv\\.so|libnsl\\.so|libcrypt\\.so|libanl\\.so|libcamera|libpisp|libgst|libgstreamer|libglib|libgobject|libgio|libgmodule|libgthread|liborc-|libudev|libyaml-0|libdw|libunwind|libffi|libpcre2-)"
)

function(_catcheye_find_runtime_dependency dep_name out_var)
    foreach(search_dir IN LISTS _catcheye_search_dirs)
        set(candidate "${search_dir}/${dep_name}")
        if(EXISTS "${candidate}" OR IS_SYMLINK "${candidate}")
            set(${out_var} "${candidate}" PARENT_SCOPE)
            return()
        endif()
    endforeach()

    set(${out_var} "" PARENT_SCOPE)
endfunction()

function(_catcheye_collect_needed elf_file out_var)
    execute_process(
        COMMAND "${_catcheye_readelf}" -d "${elf_file}"
        RESULT_VARIABLE readelf_result
        OUTPUT_VARIABLE readelf_output
        ERROR_QUIET
    )

    if(NOT readelf_result EQUAL 0)
        set(${out_var} "" PARENT_SCOPE)
        return()
    endif()

    string(REGEX MATCHALL "Shared library: \\[[^]]+\\]" needed_matches "${readelf_output}")
    set(needed_libs)
    foreach(match IN LISTS needed_matches)
        string(REGEX REPLACE ".*\\[([^]]+)\\].*" "\\1" needed_name "${match}")
        list(APPEND needed_libs "${needed_name}")
    endforeach()

    set(${out_var} "${needed_libs}" PARENT_SCOPE)
endfunction()

set(_catcheye_runtime_queue "${_catcheye_install_bindir}/catcheye-guard-bin")
set(_catcheye_seen_files)

while(_catcheye_runtime_queue)
    list(POP_FRONT _catcheye_runtime_queue current_file)

    if(NOT EXISTS "${current_file}" AND NOT IS_SYMLINK "${current_file}")
        continue()
    endif()

    get_filename_component(current_realpath "${current_file}" REALPATH)
    if(current_realpath IN_LIST _catcheye_seen_files)
        continue()
    endif()
    list(APPEND _catcheye_seen_files "${current_realpath}")

    _catcheye_collect_needed("${current_file}" needed_libs)
    foreach(dep_name IN LISTS needed_libs)
        if(dep_name MATCHES "${_catcheye_skip_runtime_regex}")
            continue()
        endif()

        _catcheye_find_runtime_dependency("${dep_name}" dep_path)
        if(NOT dep_path)
            message(WARNING "Runtime dependency not found in install tree or sysroot: ${dep_name}")
            continue()
        endif()

        set(installed_dep "${_catcheye_install_libdir}/${dep_name}")
        if(NOT EXISTS "${installed_dep}" AND NOT IS_SYMLINK "${installed_dep}")
            message(STATUS "Installing runtime dependency: ${dep_name}")
            file(COPY "${dep_path}" DESTINATION "${_catcheye_install_libdir}" FOLLOW_SYMLINK_CHAIN)
        endif()

        if(EXISTS "${installed_dep}" OR IS_SYMLINK "${installed_dep}")
            list(APPEND _catcheye_runtime_queue "${installed_dep}")
        else()
            list(APPEND _catcheye_runtime_queue "${dep_path}")
        endif()
    endforeach()
endwhile()

cmake_policy(POP)

#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
APP_ROOT="$(CDPATH= cd -- "${SCRIPT_DIR}/.." && pwd)"
LIB_DIR="${APP_ROOT}/lib"
LIBCAMERA_ROOT_DIR="${LIB_DIR}/aarch64-linux-gnu/libcamera"
LIBCAMERA_IPA_MODULE_DIR="${LIBCAMERA_ROOT_DIR}/ipa"
LIBCAMERA_IPA_CONFIG_DIR="${APP_ROOT}/share/libcamera/ipa"
LIBCAMERA_BIN="${SCRIPT_DIR}/catcheye-guard-bin"

export LD_LIBRARY_PATH="${LIB_DIR}${LD_LIBRARY_PATH:+:${LD_LIBRARY_PATH}}"
export LIBCAMERA_IPA_MODULE_PATH="${LIBCAMERA_IPA_MODULE_DIR}${LIBCAMERA_IPA_MODULE_PATH:+:${LIBCAMERA_IPA_MODULE_PATH}}"
export LIBCAMERA_IPA_PROXY_PATH="${LIBCAMERA_ROOT_DIR}${LIBCAMERA_IPA_PROXY_PATH:+:${LIBCAMERA_IPA_PROXY_PATH}}"
export LIBCAMERA_IPA_CONFIG_PATH="${LIBCAMERA_IPA_CONFIG_DIR}${LIBCAMERA_IPA_CONFIG_PATH:+:${LIBCAMERA_IPA_CONFIG_PATH}}"

exec "${LIBCAMERA_BIN}" "$@"

{
  "python.autoComplete.extraPaths": [
    "/opt/ros/jazzy/lib/python3/dist-packages"
  ],
  "python.analysis.extraPaths": [
    "/opt/ros/jazzy/lib/python3/dist-packages",
    "~/ros_ws/src/amr_autonomous/scripts"
  ],
  "terminal.integrated.env.linux": {
    "CMAKE_PREFIX_PATH": "/opt/ros/jazzy:/usr",
    "LD_LIBRARY_PATH": "/opt/ros/jazzy/lib:/usr/lib:/usr/lib/x86_64-linux-gnu",
    "PYTHONPATH": "~/ros_ws/devel/lib/python3/dist-packages:/opt/ros/jazzy/lib/python3/dist-packages:/usr/local/lib/python3.8/dist-packages:/usr/lib/python3/dist-packages:~/catkin_ws/src"
  },
  "cmake.ignoreCMakeListsMissing": true,
  "cmake.configureOnOpen": false,
  "cmake.configureOnEdit": false,
  "C_Cpp.intelliSenseEngine": "disabled",
  "clangd.path": "/usr/bin/clangd",
  "clangd.arguments": [
    "--compile-commands-dir=build",
    "--background-index",
    "--all-scopes-completion",
    "--suggest-missing-includes",
    "--completion-style=detailed",
    "--pch-storage=memory",
    "--limit-results=50",
    "--j=6",
    "--log=error",
    "--header-insertion=never",
    "--enable-config",
    "--clang-tidy"
  ],
  "clangd.enable": true,
  "files.associations": {
    "*.repose": "yaml",
    "*.world": "xml",
    "*.urdf": "xml",
    "*.xacro": "xml",
    "*.launch": "xml",
    "*.yaml": "yaml",
    "*.yml": "yaml",
    "jacobi": "cpp",
    "regex": "cpp",
    "typeinfo": "cpp",
    "geometry": "cpp",
    "cholesky": "cpp",
    "core": "cpp",
    "eigenvalues": "cpp",
    "householder": "cpp",
    "lu": "cpp",
    "qr": "cpp",
    "svd": "cpp",
    "stdvector": "cpp"
  },
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  "terminal.integrated.scrollback": 100000,
  "editor.minimap.enabled": false,
  "editor.mouseWheelZoom": true,
  "editor.renderControlCharacters": true,
  "editor.rulers": [140],
  "editor.insertSpaces": true,
  "editor.tabSize": 4,
  "editor.detectIndentation": false,
  "editor.suggestOnTriggerCharacters": true,
  "editor.acceptSuggestionOnEnter": "on",
  "editor.wordBasedSuggestions": "off",
  "editor.parameterHints.enabled": true,
  "editor.inlineSuggest.enabled": true,
  "editor.suggest.showInlineDetails": false,
  "editor.suggest.showStatusBar": false,
  "editor.wordWrap": "on",
  "editor.quickSuggestions": {
    "other": true,
    "comments": false,
    "strings": true
  },
  "autopep8.args": ["--max-line-length=140"],
  "[cpp]": {
    "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd",
    "editor.formatOnSave": true
  },
  "[python]": {
    "editor.defaultFormatter": "ms-python.autopep8",
    "editor.formatOnSave": true
  },
  "files.exclude": {
    "**/build": false,
    "**/build/**": false,
    "**/devel": true,
    "**/devel/**": true,
    "**/install": false,
    "**/logs": true,
    "**/logs/**": true,
    "**/log": true,
    "**/log/**": true,
    "**/.catkin_tools": true,
    "**/.cache": true,
    "**/.git": true,
    "**/.idea": true,
    "**/__pycache__": true,
    "**/__pycache__/**": true,
    "**/.venv": true,
    "**/node_modules": true
  },
  "search.exclude": {
    "**/build": true,
    "**/build/**": true,
    "**/devel": true,
    "**/devel/**": true,
    "**/install": true,
    "**/install/**": true,
    "**/logs": true,
    "**/logs/**": true,
    "**/log": true,
    "**/log/**": true,
    "**/.catkin_tools": true,
    "**/.cache": true,
    "**/.git": true,
    "**/__pycache__": true,
    "**/__pycache__/**": true,
    "**/.venv": true,
    "**/node_modules": true
  },
  "files.watcherExclude": {
    "**/build": true,
    "**/build/**": true,
    "**/devel": true,
    "**/devel/**": true,
    "**/install": true,
    "**/install/**": true,
    "**/.venv/**": true,
    "**/node_modules/**": true,
    "**/__pycache__/": true,
    "**/__pycache__/**": true
  },
  "python.analysis.exclude": [
    "**/build",
    "**/build/**",
    "**/devel",
    "**/devel/**",
    "**/install",
    "**/install/**",
    "**/logs",
    "**/logs/**",
    "**/log",
    "**/log/**",
    "**/.catkin_tools",
    "**/.cache",
    "**/.git",
    "**/__pycache__",
    "**/__pycache__/**",
    "**/.venv",
    "**/node_modules"
  ],
  "cmake.automaticReconfigure": false,
  "cmake.buildBeforeRun": false,
  "cmake.autoSelectActiveFolder": false,
  "ROS2.distro": "jazzy",
  "chatgpt.openOnStartup": false
}
